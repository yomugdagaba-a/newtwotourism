# Database
DATABASE_URL="postgresql://postgres.gclzstgdcguzocxxgkdv:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres"
DIRECT_URL="postgresql://postgres.gclzstgdcguzocxxgkdv:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# JWT
# Access token expires after 30 minutes (refreshed automatically on activity)
JWT_SECRET="your-secret-key-here"
JWT_EXPIRATION="30m"
# Refresh token expires after 7 hours (maximum session duration)
JWT_REFRESH_EXPIRATION="7h"

# Server
NODE_ENV="development"
PORT=9001
FRONTEND_URL="http://localhost:3000"

# Email (Gmail SMTP)
# Get app password from: https://myaccount.google.com/apppasswords
GMAIL_USER="your-gmail@gmail.com"
GMAIL_APP_PASSWORD="your-16-char-app-password"

# Email Override (Development/Testing - Optional)
# Uncomment to redirect all emails to a single address for testing
# TEST_EMAIL_OVERRIDE="your-test-email@example.com"

# File Upload
UPLOAD_DIR="uploads"
MAX_FILE_SIZE=10485760

# Security
MAX_FAILED_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
MAX_IP_ATTEMPTS_PER_HOUR=100

# Audit
AUDIT_ENABLED=true
AUDIT_RETENTION_DAYS=90

# Redis (for rate limiting - get from Leapcell Redis service)
# On Leapcell: Dashboard → Redis → Connection String
REDIS_URL="redis://default:[YOUR-REDIS-PASSWORD]@[YOUR-REDIS-HOST]:6379"
# OR use individual settings:
# REDIS_HOST="your-redis-host"
# REDIS_PORT=6379
# REDIS_PASSWORD="your-redis-password"

# Rate Limiting
RATE_LIMIT_GLOBAL_MAX=1000
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_REGISTER_MAX=3
RATE_LIMIT_PASSWORD_RESET_MAX=3
RATE_LIMIT_EMAIL_VERIFICATION_MAX=5
RATE_LIMIT_BOOKING_MAX=10
RATE_LIMIT_FILE_UPLOAD_MAX=20
RATE_LIMIT_RATING_MAX=10
RATE_LIMIT_ADMIN_MAX=500
