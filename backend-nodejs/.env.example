# Database
DATABASE_URL="postgresql://postgres.gclzstgdcguzocxxgkdv:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres"
DIRECT_URL="postgresql://postgres.gclzstgdcguzocxxgkdv:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# JWT
JWT_SECRET="your-secret-key-here"
JWT_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# Server
NODE_ENV="development"
PORT=9001
FRONTEND_URL="http://localhost:3000"

# Email Configuration
# Choose ONE of the following email providers:

# Option 1: SendGrid (Recommended for Render free tier)
# Free tier: 100 emails/day, works on Render free tier (uses HTTP API)
# Get API key: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY="your-sendgrid-api-key"
SENDGRID_FROM_EMAIL="noreply@yourdomain.com"
SENDGRID_FROM_NAME="North Wollo Tourism"

# Option 2: Gmail SMTP (For local development or paid Render plans)
# Get app password from: https://myaccount.google.com/apppasswords
# Note: Gmail SMTP is blocked on Render free tier
GMAIL_USER="your-gmail@gmail.com"
GMAIL_APP_PASSWORD="your-16-char-app-password"

# Email Override (Development/Testing - Optional)
# Uncomment to redirect all emails to a single address for testing
# TEST_EMAIL_OVERRIDE="your-test-email@example.com"

# File Upload
UPLOAD_DIR="uploads"
MAX_FILE_SIZE=10485760

# Security
MAX_FAILED_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
MAX_IP_ATTEMPTS_PER_HOUR=100

# Audit
AUDIT_ENABLED=true
AUDIT_RETENTION_DAYS=90
