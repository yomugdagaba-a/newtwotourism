
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==================== ENUMS ====================

enum TourismCategory {
  HERITAGE
  HIGHLAND
  CAVERN
  AQUATICS
  CULTURE
  MODERN
}

enum PlaceStatus {
  ACTIVE
  BLOCKED
}

enum BookingStatus {
  REQUESTED
  OWNER_ACCEPTED
  COST_PROPOSED
  PAID
  APPROVED
  REJECTED
}

enum MapPointType {
  TOURISM_PLACE
  HOTEL
  ROAD
}

enum RoadType {
  CAR
  FOOT
  HORSE
  PLANE
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  REGISTER
  PASSWORD_RESET_REQUEST
  PASSWORD_RESET_CONFIRM
  EMAIL_VERIFICATION_SEND
  EMAIL_VERIFICATION_CONFIRM
  ACCOUNT_LOCKED
  ACCOUNT_UNLOCKED
  AUTHORIZATION_CHECK
  TOKEN_REFRESH
  SESSION_EXPIRED
  EXPORT
  IMPORT
}

// ==================== CORE ENTITIES ====================

model Role {
  id    Int     @id @default(autoincrement())
  name  String  @unique
  users User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("roles")
}

model User {
  id                Int     @id @default(autoincrement())
  username          String  @unique
  passwordHash      String
  email             String? @unique
  fullName          String
  active            Boolean @default(true)
  emailVerified     Boolean @default(false)
  emailVerifiedAt   DateTime?

  // Relations
  roles             Role[]
  hotelBookings     HotelBooking[]
  hotelOwnedHotels  Hotel[] @relation("HotelOwner")
  tourismRatings    TourismRating[]
  hotelRatings      HotelRating[]
  emailTokens       EmailVerificationToken[]
  passwordTokens    PasswordResetToken[]
  refreshTokens     RefreshToken[]
  loginAttempts     LoginAttempt[]
  accountLockouts   AccountLockout[]
  auditLogs         AuditLogEntry[]
  bookingMessages   BookingMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model EmailVerificationToken {
  id        Int     @id @default(autoincrement())
  userId    Int
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String  @unique
  email     String?
  expiresAt DateTime
  verified  Boolean @default(false)
  attemptCount Int @default(0)
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id        Int     @id @default(autoincrement())
  userId    Int
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String  @unique
  expiresAt DateTime
  used      Boolean @default(false)
  attemptCount Int @default(0)
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@map("password_reset_tokens")
}

model RefreshToken {
  id        Int     @id @default(autoincrement())
  userId    Int
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String  @unique
  expiresAt DateTime

  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

model LoginAttempt {
  id        Int     @id @default(autoincrement())
  userId    Int?
  user      User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  ipAddress String
  success   Boolean
  reason    String?

  createdAt DateTime @default(now())

  @@map("login_attempts")
}

model AccountLockout {
  id        Int     @id @default(autoincrement())
  userId    Int     @unique
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  lockedUntil DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("account_lockouts")
}

// ==================== TOURISM ENTITIES ====================

model TourismPlace {
  id            Int     @id @default(autoincrement())
  name          String
  categories    TourismCategory[] @default([])
  description   String
  wereda        String
  kebele        String
  bestTime      String?
  peaceInfo     String?
  visitTime     String? // visit duration as descriptive text
  languages     String[] @default([])
  status        PlaceStatus @default(ACTIVE)
  viewersCount  Int @default(0)
  imageUrl      String?
  latitude      Float?  // NEW: For map integration
  longitude     Float?  // NEW: For map integration

  // Relations
  images        TourismImage[]
  hotels        Hotel[]
  ratings       TourismRating[]
  mapPoints     MapPoint[]
  roadInfos     RoadInfo[]
  languageGuiders LanguageGuider[]
  views         TourismView[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tourism_places")
}

model TourismImage {
  id              Int     @id @default(autoincrement())
  tourismPlaceId  Int
  tourismPlace    TourismPlace @relation(fields: [tourismPlaceId], references: [id], onDelete: Cascade)
  imageUrl        String
  displayOrder    Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tourism_images")
}

model TourismRating {
  id              Int     @id @default(autoincrement())
  tourismPlaceId  Int
  tourismPlace    TourismPlace @relation(fields: [tourismPlaceId], references: [id], onDelete: Cascade)
  userId          Int
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating          Int // 1-5
  comment         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tourismPlaceId, userId])
  @@map("tourism_ratings")
}

// ==================== HOTEL ENTITIES ====================

model Hotel {
  id              Int     @id @default(autoincrement())
  tourismPlaceId  Int?
  tourismPlace    TourismPlace? @relation(fields: [tourismPlaceId], references: [id], onDelete: SetNull)
  ownerId         Int?
  owner           User?   @relation("HotelOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  name            String
  starRating      Int // 1-5
  contactInfo     String
  policies        String?
  description     String?
  active          Boolean @default(true)
  latitude        Float?  // For map integration
  longitude       Float?  // For map integration

  // Relations
  images          HotelImage[]
  bookings        HotelBooking[]
  ratings         HotelRating[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("hotels")
}

model HotelImage {
  id        Int     @id @default(autoincrement())
  hotelId   Int
  hotel     Hotel   @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  imageUrl  String
  displayOrder Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("hotel_images")
}

model HotelRating {
  id        Int     @id @default(autoincrement())
  hotelId   Int
  hotel     Hotel   @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  userId    Int
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Int // 1-5
  comment   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([hotelId, userId])
  @@map("hotel_ratings")
}

model BookingStatusEntity {
  id    Int     @id @default(autoincrement())
  name  BookingStatus @unique
  bookings HotelBooking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("booking_statuses")
}

model HotelBooking {
  id                Int     @id @default(autoincrement())
  hotelId           Int
  hotel             Hotel   @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  userId            Int
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  checkIn           DateTime
  checkOut          DateTime
  numberOfGuests    Int
  numberOfRooms     Int?
  specialRequests   String?
  clientPhone       String?
  clientEmail       String?
  totalCost         Decimal? @db.Decimal(10, 2)
  receiptImageUrl   String?
  rejectionReason   String?
  problemReport     String?
  problemReported   Boolean @default(false)
  hiddenFromClient  Boolean @default(false) // Client can hide booking from their view
  hiddenFromOwner   Boolean @default(false) // Owner can hide booking from their view
  statusId          Int
  status            BookingStatusEntity @relation(fields: [statusId], references: [id])

  // Relations
  messages          BookingMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("hotel_bookings")
}

model BookingMessage {
  id        Int     @id @default(autoincrement())
  bookingId Int
  booking   HotelBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  userId    Int
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   String
  isFromOwner Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("booking_messages")
}

// ==================== HORSE SERVICE ENTITIES ====================

model HorseService {
  id          Int     @id @default(autoincrement())
  name        String
  description String?
  pricePerHour Decimal @db.Decimal(10, 2)
  maxCapacity Int
  active      Boolean @default(true)
  roadInfoId  Int?
  roadInfo    RoadInfo? @relation(fields: [roadInfoId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("horse_services")
}

// ==================== LANGUAGE GUIDER ENTITIES ====================

model LanguageGuider {
  id              Int     @id @default(autoincrement())
  name            String
  languages       String[]
  experience      String?
  contactInfo     String
  active          Boolean @default(true)
  tourismPlaceId  Int?
  tourismPlace    TourismPlace? @relation(fields: [tourismPlaceId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("language_guiders")
}

// ==================== MAP & ROAD ENTITIES ====================

model MapPoint {
  id              Int     @id @default(autoincrement())
  tourismPlaceId  Int?
  tourismPlace    TourismPlace? @relation(fields: [tourismPlaceId], references: [id], onDelete: SetNull)
  name            String
  type            MapPointType
  latitude        Float
  longitude       Float
  description     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("map_points")
}

model RoadInfo {
  id              Int     @id @default(autoincrement())
  tourismPlaceId  Int?
  tourismPlace    TourismPlace? @relation(fields: [tourismPlaceId], references: [id], onDelete: SetNull)
  
  // Road information
  name            String
  type            RoadType
  description     String?
  condition       String?
  active          Boolean @default(true)
  
  // Distance fields for different transportation types
  distance        Float?              // Legacy field (kept for backward compatibility)
  distanceByCar   Float?              // Distance by car in km
  distanceByFoot  Float?              // Distance by foot in km
  distanceByHorse Float?              // Distance by horse in km
  distanceByPlane Float?              // Distance by plane in km
  totalDistance   Float?              // Total distance in km
  
  horseServices   HorseService[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("road_infos")
}

// ==================== HERO IMAGE ENTITIES ====================

model HeroImage {
  id           Int     @id @default(autoincrement())
  imageUrl     String
  title        String?
  description  String?
  displayOrder Int     @default(0)
  active       Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("hero_images")
}

// ==================== AUDIT ENTITIES ====================

model AuditLogEntry {
  id            Int     @id @default(autoincrement())
  userId        Int?
  user          User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  action        AuditAction
  entityType    String
  entityId      Int?
  changes       String? // JSON string of changes
  ipAddress     String?
  userAgent     String?
  status        String  @default("SUCCESS")
  errorMessage  String?

  createdAt DateTime @default(now())

  @@map("audit_log_entries")
}

// ==================== VIEW TRACKING ====================

model TourismView {
  id              Int     @id @default(autoincrement())
  tourismPlaceId  Int
  tourismPlace    TourismPlace @relation(fields: [tourismPlaceId], references: [id], onDelete: Cascade)
  sessionId       String  // Browser fingerprint or session ID
  ipAddress       String?
  userAgent       String?
  viewedAt        DateTime @default(now())

  @@index([tourismPlaceId, sessionId, viewedAt])
  @@map("tourism_views")
}
